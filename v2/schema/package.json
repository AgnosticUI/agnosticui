{
  "name": "@agnosticui/schema",
  "version": "2.0.0-alpha.1",
  "description": "Standard Schema-validated JSON catalog for AgnosticUI SDUI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsc",
    "codegen": "tsx scripts/codegen.ts",
    "check-codegen": "tsx scripts/check-codegen.ts",
    "m4": "npx tsx m4-llm-test.ts",
    "m4:dry": "npx tsx m4-llm-test.ts --dry-run"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "ts-morph": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
